---
import { CONTENT_PADDING } from '@constants/layout';
import { siteConfig } from '@constants/site-config';
import Layout from '@layouts/Layout.astro';

const title = `DataVision (iframe) | ${siteConfig.title}`;
const description = 'DataEase 嵌入式仪表板展示 — iframe 方式';

const DE_BASE_URL = 'https://spell-dig-marsh-somewhere.trycloudflare.com';
const DE_DV_ID = '1247187068585644032';
const DE_APP_ID = 'rJkK3tjsEAAhEgfl';
const DE_APP_SECRET = import.meta.env.DE_APP_SECRET || '04eYYEuUdVlAGrN1';
---

<Layout title={title} description={description}>
  <div class={`bg-gradient-start shadow-box tablet:shadow-none flex flex-col ${CONTENT_PADDING.standard}`}>
    <div class="flex items-center justify-between mb-2">
      <span id="bi-status" class="text-xs px-2 py-0.5 rounded-full" style="background: rgba(245,158,11,0.15); color: #f59e0b;">
        正在加载仪表板...
      </span>
      <a href="/tools/bi" class="text-xs underline text-[var(--text-color-secondary)]">切回 DIV 嵌入</a>
    </div>
    <iframe id="de-view-iframe" style="width: 100%; height: calc(100vh - 90px); border: 0;" src="about:blank" />
  </div>
</Layout>

<script define:vars={{ DE_APP_ID, DE_APP_SECRET, DE_BASE_URL, DE_DV_ID }}>
  function b64url(str) {
    return btoa(str).replace(/\+/g, '-').replace(/\//g, '_').replace(/=/g, '');
  }

  async function generateToken(appId, appSecret, payload) {
    var header = { alg: 'HS256', typ: 'JWT' };
    var headerB64 = b64url(JSON.stringify(header));
    var payloadB64 = b64url(JSON.stringify(payload));
    var data = headerB64 + '.' + payloadB64;
    var encoder = new TextEncoder();
    var key = await crypto.subtle.importKey('raw', encoder.encode(appSecret), { name: 'HMAC', hash: 'SHA-256' }, false, ['sign']);
    var sig = await crypto.subtle.sign('HMAC', key, encoder.encode(data));
    var sigBytes = new Uint8Array(sig);
    var sigChars = [];
    for (var i = 0; i < sigBytes.length; i++) sigChars.push(String.fromCharCode(sigBytes[i]));
    return data + '.' + b64url(sigChars.join(''));
  }

  window.addEventListener('load', async function () {
    var statusEl = document.getElementById('bi-status');
    var iframe = document.getElementById('de-view-iframe');
    if (!statusEl || !iframe) return;

    function setStatus(text, isError) {
      statusEl.textContent = text;
      if (isError) {
        statusEl.style.background = 'rgba(239,68,68,0.15)';
        statusEl.style.color = '#ef4444';
      } else {
        statusEl.style.background = 'rgba(16,185,129,0.1)';
        statusEl.style.color = '#10b981';
      }
    }

    try {
      setStatus('正在生成令牌...');
      var now = Math.floor(Date.now() / 1000);
      var token = await generateToken(DE_APP_ID, DE_APP_SECRET, {
        uid: 1, oid: 1, appId: DE_APP_ID, account: 'admin', exp: now + 960 * 60
      });

      setStatus('正在加载...');
      // URL token 方式：将 embeddedToken 拼在 hash query 中
      var viewUrl = DE_BASE_URL + '/#/chart-view?busiFlag=dashboard&dvId=' + DE_DV_ID
        + '&type=Dashboard&embeddedToken=' + encodeURIComponent(token);
      iframe.src = viewUrl;

      setStatus('仪表板已加载');
      setTimeout(function () {
        var header = iframe.parentElement?.querySelector('.flex.items-center.justify-between');
        if (header) header.style.display = 'none';
      }, 3000);
    } catch (err) {
      setStatus('加载失败: ' + (err && err.message || err), true);
      console.error('DataEase iframe error:', err);
    }
  });
</script>
